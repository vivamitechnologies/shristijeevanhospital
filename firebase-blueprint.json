{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled medical appointment.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "department": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] }
      },
      "required": ["name", "phone", "date", "department", "createdAt", "status"]
    }
  },
  "firestore": {
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/entities/Appointment" },
      "description": "Stores patient appointment requests."
    }
  }
}
